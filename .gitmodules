[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	branch = HEAD
[submodule "edibble"]
	path = edibble
	url = https://github.com/emitanaka/edibble
[submodule "nestr"]
	path = nestr
	url = https://github.com/emitanaka/nestr
[submodule "smbdata"]
	path = smbdata
	url = https://github.com/emitanaka/smbdata
